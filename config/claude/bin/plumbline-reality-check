#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Resolve a real python3 (stdlib-only gates). Skip the trailofbits modern-python
# PATH shim (refuses a bare `python3`) by preferring absolute interpreters, so the
# fail-closed Stop hook stays runnable regardless of the hook's PATH.
PY="python3"
for c in /usr/bin/python3 /opt/homebrew/bin/python3 "$HOME/.venv/bin/python3"; do
  [ -x "$c" ] && { PY="$c"; break; }
done
exec "$PY" "$SCRIPT_DIR/../lib/plumbline_reality.py" "$@"
