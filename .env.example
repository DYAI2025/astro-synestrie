# Bazodiac BFF environment template.
# Copy to .env for local development. NEVER commit real secrets.
# All secrets stay server-side. Do NOT use VITE_* for any secret — VITE_* is
# inlined into the browser bundle and would leak keys publicly.

NODE_ENV=development
APP_URL=http://localhost:3000

# --- FuFirE upstream (server-side only) ---
FUFIRE_API_URL=http://localhost:8000
FUFIRE_API_KEY=replace_me
FUFIRE_API_PATH_PREFIX=v1
# Optional display/release metadata only; not used as the upstream route prefix.
FUFIRE_API_VERSION=
REQUEST_TIMEOUT_MS=12000

# --- Feature flags ---
# When false (default), no local astrology product calculation is allowed.
# Local results may only appear when explicitly enabled AND labelled fallback-local.
ENABLE_LOCAL_ASTROLOGY_FALLBACK=false
# When false (default), demo/sample profiles and mock places are not product paths.
ENABLE_DEMO_PROFILES=false

# --- Places / Timezone ---
# Keyless providers: Photon (photon.komoot.io, OSM) for place search and
# tz-lookup (offline) for coordinate→timezone. No API key required.

# --- Optional: Gemini poetic reading (server-side only) ---
GEMINI_API_KEY=replace_me_optional

# --- Supabase (Persistenz, Opt-in — REQ-P3-001 bis REQ-P3-006) ---
# Server-side only (BFF): Service-Role-Key NEVER in browser bundle / VITE_* prefix.
SUPABASE_URL=https://ykoijifgweoapitabgxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me_secret
# Browser-side (anon key only — baked into Vite bundle at build time):
VITE_SUPABASE_URL=https://ykoijifgweoapitabgxx.supabase.co
VITE_SUPABASE_ANON_KEY=replace_me_anon_key

# --- ElevenLabs ConvAI Sprach-Agenten (Eve & Levi) ---
# Agent-IDs sind ÖFFENTLICHE Kennungen (kein Secret) — sie werden bewusst als
# VITE_* in den Browser-Bundle gebacken. Personas & System-Prompts leben in der
# ElevenLabs-Console, nicht im Code. Ohne ID bleibt der jeweilige Agent
# unsichtbar (ehrlicher Hidden-State statt kaputtem Button).
VITE_ELEVENLABS_AGENT_ID_LEVI=
VITE_ELEVENLABS_AGENT_ID_EVE=
